{
  "code": "REPORT_CODE", //通过查询reports表获取masterreport,去重后获得
  "fightId": 1,//可选，默认为0，表示整个报告，如果指定了fightId，则只返回该fight的数据
  "report": {
    "title": "Report Title", //reports表中的title字段
    "startTime": 1700000000000,//reports表中的startTime字段，单位为毫秒
    "endTime": 1700003600000,//reports表中的endTime字段，单位为毫秒
    "fights": [  //通过fightsyncmaps表获取fight数据
      {
        "id": 1, //fightsyncmaps中的fightId字段 也可以通过拆分masterid获得
        "name": "Fight Name", //fightsyncmaps中的name字段
        "kill": false, //fightsyncmaps中的kill字段
        "startTime": 0, //fightsyncmaps中的startTime字段，单位为毫秒，相对于报告的startTime
        "endTime": 180000, //fightsyncmaps中的endTime字段，单位为毫秒，相对于报告的startTime
        "fightPercentage": 0, //fightsyncmaps中的fightPercentage字段，表示该fight在整个报告中的占比，单位为百分比
        "bossPercentage": 0, //fightsyncmaps中的bossPercentage字段，表示该fight中boss的占比，单位为百分比
        "encounterID": 1234,//fightsyncmaps中的encounterID字段
        "difficulty": 101, //fightsyncmaps中的difficulty字段，表示该fight的难度，具体数值含义请参考游戏数据文档
        "gameZone": { "id": 999, "name": "Zone Name" } //fightsyncmaps中的gameZoneID字段，通过gamezones表获取对应的id和name字段
      }
    ],
    "masterData": { //通过reports的reportmetadata获得
      "actors": [
        {
          "id": 1001,
          "name": "Player A",
          "subType": "SAM",
          "gameID": 1,
          "type": "Player"
        },
        {
          "id": 2001,
          "name": "Boss",
          "subType": "Unknown",
          "gameID": 0,
          "type": "NPC"
        }
      ]
    }
  },
  "events": [//在本地文件中获得
    {
      "type": "damage",
      "timestamp": 1700000005000,
      "sourceID": 1001,
      "targetID": 2001,
      "ability": { "guid": 12345, "name": "Skill Name" },
      "amount": 100
    }
  ]
}